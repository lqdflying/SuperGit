{
  "name": "supergit",
  "displayName": "SuperGit",
  "description": "Visual Git commit history, branch tracking, and files diff with multi-remote support",
  "version": "2.0.0",
  "publisher": "lqdflying",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lqdflying/SuperGit.git"
  },
  "bugs": {
    "url": "https://github.com/lqdflying/SuperGit/issues"
  },
  "homepage": "https://github.com/lqdflying/SuperGit#readme",
  "icon": "assets/icon.png",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "SCM Providers",
    "Visualization"
  ],
  "activationEvents": [
    "onStartupFinished",
    "workspaceContains:.git"
  ],
  "main": "./dist/extension.js",
  "extensionDependencies": [
    "vscode.git"
  ],
  "contributes": {
    "configuration": {
      "title": "SuperGit",
      "properties": {
        "superGit.debug": {
          "type": "boolean",
          "default": false,
          "description": "Enable verbose SuperGit debug logging in the SuperGit output channel and Extension Host log."
        },
        "superGit.addUpstream.skipRemoteProbe": {
          "type": "boolean",
          "default": false,
          "description": "Skip ls-remote before Add Remote Tracking and go straight to push. Faster, but branches that exist on the remote without a local tracking ref may be pushed instead of fetched."
        }
      }
    },
    "commands": [
      {
        "command": "superGit.show",
        "title": "SuperGit: Show Graph",
        "icon": "$(git-commit)"
      },
      {
        "command": "superGit.showLogs",
        "title": "SuperGit: Show Logs",
        "icon": "$(output)"
      },
      {
        "command": "superGit.toggleDebug",
        "title": "SuperGit: Toggle Debug Logging",
        "icon": "$(bug)"
      }
    ],
    "menus": {
      "scm/title": [
        {
          "command": "superGit.show",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "superGit.show"
        },
        {
          "command": "superGit.showLogs"
        },
        {
          "command": "superGit.toggleDebug"
        }
      ]
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.webview.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:integration": "node ./dist/test/runTest.js",
    "package": "vsce package --no-dependencies --allow-missing-repository --githubBranch main"
  },
  "dependencies": {
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/vscode": "^1.100.0",
    "@vscode/test-electron": "^2.5.0",
    "@vscode/vsce": "^3.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "esbuild": "^0.25.0",
    "typescript": "~6.0.0",
    "vitest": "^3.0.0"
  }
}
